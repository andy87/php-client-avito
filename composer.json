{
  "name": "andy87/php-client-avito",
  "description": "Typed PHP client for Avito Public API.",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "php_client_avito\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "php_client_avito\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.1",
    "andy87/php-client-sdk": "^0.4.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "analyse": "phpstan analyse src tests --level=5",
    "generate": "node tools/generate-avito-openapi.mjs",
    "test": "phpunit"
  }
}
