{
  "name": "andy87/php-client-avito",
  "description": "Typed PHP client for Avito Public API.",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Andy87\\ClientsAvito\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Andy87\\ClientsAvito\\Tests\\": "tests/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../clients-sdk",
      "options": {
        "symlink": true,
        "versions": {
          "andy87/clients-sdk": "0.3.0"
        }
      }
    }
  ],
  "require": {
    "php": ">=8.1",
    "andy87/clients-sdk": "^0.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "generate": "node tools/generate-avito-openapi.mjs",
    "test": "phpunit"
  }
}
